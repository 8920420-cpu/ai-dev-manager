# Скопируй в .env и поменяй значения
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=marshrutka
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@marshrutka.local
TZ=Europe/Moscow
# Ключи шифрования Semaphore — сгенерировать один раз и НЕ менять
# (потеря ключа = все секреты в Key Store нерасшифровываемы):
#   head -c32 /dev/urandom | base64
SEMAPHORE_ACCESS_KEY_ENCRYPTION=
SEMAPHORE_COOKIE_HASH=
SEMAPHORE_COOKIE_ENCRYPTION=
# API-токен Timeweb Cloud (панель -> «API и Terraform»); балансировщик, VPS.
# Дубль хранится в Key Store Semaphore («timeweb-cloud-api (token)»).
TIMEWEB_CLOUD_TOKEN=
