{
  "name": "ai-dev-manager",
  "workingDirectory": ".",
  "timeoutMinutes": 15,
  "stages": {
    "build": [
      "docker compose build"
    ],
    "deploy": [
      "docker compose up -d"
    ],
    "smoke": [
      "curl -f --retry 15 --retry-delay 2 --retry-connrefused --retry-all-errors http://localhost:4186/health",
      "curl -f --retry 5 --retry-delay 2 --retry-all-errors http://localhost:4186/"
    ]
  }
}
