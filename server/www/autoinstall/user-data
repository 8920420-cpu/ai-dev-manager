#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: ubuntu-server
    username: admin
    password: "$6$o.DQ7PD8Oz95IgUM$yyS8wH.6U8xi1g1GPAmSoyzo.w1r716/yAVrEeHm9Cevnqg1LV4Kbr0CKnUm1E5FFeuuPjoVxSi1UZAztDb.l1"
  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDSLtCmwyHkndnX8jA50VG9VbJMe4ns6JlWZe18rILlX admin@albia-pxe"
  storage:
    layout:
      name: direct
  packages:
    - curl
    - git
    - qemu-guest-agent
  late-commands:
    - curtin in-target --target=/target -- systemctl enable ssh
    - curtin in-target --target=/target -- bash -lc 'echo "admin ALL=(ALL) NOPASSWD:ALL" >/etc/sudoers.d/90-admin-nopasswd && chmod 0440 /etc/sudoers.d/90-admin-nopasswd'
    - curtin in-target --target=/target -- bash -lc 'curl -fsSL http://192.168.2.200:8087/scripts/firstboot.sh -o /usr/local/sbin/albia-firstboot && chmod +x /usr/local/sbin/albia-firstboot'
    - |
      cat > /target/etc/systemd/system/albia-firstboot.service <<'EOF'
      [Unit]
      Description=Initial handoff to Albia
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/usr/local/sbin/albia-firstboot
      RemainAfterExit=yes

      [Install]
      WantedBy=multi-user.target
      EOF
    - curtin in-target --target=/target -- systemctl enable albia-firstboot.service
