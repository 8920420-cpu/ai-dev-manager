# .env.example — образец окружения для ai-dev-manager.
# Скопируйте в .env и при необходимости переопределите. Значения здесь = ДЕФОЛТЫ
# (то, что применяется, если переменная не задана). Полный разбор источников и
# контрактов — в CONFIG_AUDIT.md.
#
# Единицы: все *_MS — миллисекунды. Раннеры (codex/claude-reasoning/programmer)
# дополнительно принимают суффиксы единиц: 540000, 540s, 9m, 1h (см. envConfig.js).

# ── База данных (orchestrator) ───────────────────────────────────────────────
# Маршрут: app -> HAProxy -> PgBouncer -> PostgreSQL.
PGHOST=infra-haproxy-1
PGPORT=5000
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=orchestrator_db

# ── Пути проектов (PROJECT-PATH-MAP-001) ─────────────────────────────────────
# Родитель всех проектов на хосте; должен совпадать с projects.root_path в БД.
PROJECTS_HOST_ROOT=K:\Роботы\Golang\git

# ── Безопасность / сеть ──────────────────────────────────────────────────────
# Bearer для /api/* (пусто = выключено). TOOLS/MCP открываются в LAN только опт-ином.
ORCHESTRATOR_API_TOKEN=
# TOOLS_BIND_HOST=0.0.0.0          # открыть tools-service в LAN (только с токеном!)
# MCP_BIND_HOST=0.0.0.0            # открыть mcp-service в LAN (только с токеном!)
# TOOLS_ALLOWED_ROOTS=/projects:/app/ai-dev-manager

# ── КОНТРАКТ ТАЙМАУТОВ (CONFIG-AUDIT-001) ────────────────────────────────────
# Орфан-таймаут оркестратора ДОЛЖЕН быть БОЛЬШЕ hard-timeout раннеров, иначе реапер
# освобождает захват раньше раннера → agent_aborted по кругу. Цепочка:
#   орфан рассуждающих (10м) > hard-timeout рассуждающих раннеров (9м, start-runners.ps1)
#   орфан программиста  (25м) > hard-timeout программиста (20м, PROGRAMMER_TASK_TIMEOUT_MS)
#   орфан host-ролей    (40м) > самая долгая docker-сборка/коммит (RUNNER_HOST_TIMEOUT_MS)
#
# Орфан-таймаут РАССУЖДАЮЩЕЙ роли (db.js DEFAULT_ROLE_TIMEOUT_MS, compose). Единый = 10 мин.
RUNNER_ROLE_TIMEOUT_MS=600000
# Орфан-таймаут ПРОГРАММИСТА (CODING) — отдельно: CODING идёт 10-20 мин. 25 мин.
RUNNER_CLAUDE_TIMEOUT_MS=1500000
# Орфан-таймаут HOST-ролей (PIPELINE_SERVICE/GIT_INTEGRATOR) — отдельно: docker-сборка/
# коммит идут дольше рассуждающих. КОНТРАКТ: > RUNNER_ROLE_TIMEOUT_MS. 40 мин.
RUNNER_HOST_TIMEOUT_MS=2400000
# Лимит ходов Agent SDK у программиста (упор = max_turns_exceeded в KPI).
PROGRAMMER_MAX_TURNS=100

# ── Раннеры (хостовые, см. scripts/start-runners.ps1) ────────────────────────
# start-runners.ps1 ставит эти hard-timeout'ы = 540000 (9 мин), если не заданы в env.
# ВНИМАНИЕ: если значение УЖЕ есть в окружении (унаследовано), оно победит дефолт
# скрипта — смотрите строку "CONFIG: ... (env(inherited)/default)" в выводе.
# CLAUDE_REASONING_TASK_TIMEOUT_MS=540000   # дефолт кода 600000 (10 мин)
# CLAUDE_REASONING_CONCURRENCY=1            # дефолт кода 2; 1 = без rate-limit подписки
# CLAUDE_REASONING_MODEL=claude-sonnet-4-6
# CODEX_TASK_TIMEOUT_MS=540000              # дефолт кода 600000 (10 мин)
# CODEX_CONCURRENCY=2
# PROGRAMMER_TASK_TIMEOUT_MS=1200000        # 20 мин (дефолт кода)
# PROGRAMMER_CONCURRENCY=3                  # стартовое; на лету берётся из настроек БД
# ORCHESTRATOR_URL=http://localhost:4186

# ── Адаптивный лимитер коннектора (CONNECTOR-LIMITER-001) ────────────────────
CONNECTOR_LLM_MAX_TOKENS=2048
CONNECTOR_LIMIT_START=6
CONNECTOR_LIMIT_MIN=2
CONNECTOR_LIMIT_MAX=32
CONNECTOR_LIMIT_PROBE_AFTER=15
CONNECTOR_TPM_BUDGET=0
CONNECTOR_RETRY_MAX=1

# ── Сканер ───────────────────────────────────────────────────────────────────
SCANNER_INTAKE_PROJECT=ai-dev-manager
# SCANNER_DEBOUNCE_MS=150
# SCANNER_FALLBACK_MS=5000

# ── Управляемые серверы ──────────────────────────────────────────────────────
# Используется сервисом docker-compose `albia` и разделом UI «Серверы».
# Если образ лежит в private registry, укажите полный путь, например:
ALBIA_IMAGE=localhost:5000/albia:latest

# Server PXE subsystem (server/docker-compose.yml).
# SERVER_DATA_ROOT can point outside the repo; this is where ISO, TFTP and netboot cache live.
# SERVER_DATA_ROOT=K:\Роботы\Golang\git\server
# PXE_SERVER_IP must be the LAN IP of the Docker host that clean servers can reach.
# Start only on an isolated/provisioning LAN unless this host is the intended DHCP server.
# PXE_SERVER_IP=192.168.1.10
# PXE_ROUTER=192.168.1.1
# PXE_DNS=192.168.1.1
# PXE_DHCP_RANGE=192.168.1.200,192.168.1.240,12h
# PXE_HTTP_BIND=0.0.0.0
# PXE_HTTP_PORT=8088
# PXE_NETWORK_MODE=host
# PXE_INTERFACE=
# ALBIA_PORT=8090
# ALBIA_PROVISION_USER=admin
# Ключ провижининга — ОБЯЗАТЕЛЬНО без пассфразы (albia ходит по ssh неинтерактивно).
# ALBIA_PROVISION_SSH_KEY=/opt/albia/ssh/albia_provision_ed25519
# Локальный Docker registry (профиль `registry` в server/docker-compose.yml).
# REGISTRY_BIND=0.0.0.0
# REGISTRY_PORT=5000
# Rancher — управление k8s (профиль `rancher`), UI https://<host>:9443.
# RANCHER_IMAGE=rancher/rancher:latest
# RANCHER_HTTP_PORT=9080
# RANCHER_HTTPS_PORT=9443
# NETBOOTXYZ_WEB_PORT=3000
# NETBOOTXYZ_ASSETS_PORT=8089
# NETBOOTXYZ_TFTP_PORT=6969
