{
  "name": "ai-dev-manager-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend dependencies for AI Dev Manager",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview --port 4186",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:services": "npm --prefix orchestrator-service/backend test && npm --prefix tools-service test && npm --prefix mcp-service test && npm --prefix scanner-service test && npm --prefix tester-service test && npm --prefix pipeline-runner test && npm --prefix host-runner test && npm --prefix programmer-runner test && npm --prefix codex-runner test",
    "test:all": "npm test && npm run test:services",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chakra-ui/react": "3.36.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mantine/core": "7.17.8",
    "@mantine/hooks": "7.17.8",
    "@mui/icons-material": "9.1.1",
    "@mui/material": "9.1.1",
    "@tailwindcss/vite": "4.3.1",
    "antd": "6.4.4",
    "bootstrap": "5.3.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "html2canvas": "1.4.1",
    "lucide-react": "1.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "shadcn": "4.11.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^2.1.9"
  }
}
