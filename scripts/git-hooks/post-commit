#!/bin/sh
# RUNNER-FRESHNESS-001 — коммит, трогающий код хостовых демонов, немедленно
# запускает вотчдог свежести (точечный рестарт устаревшего демона). Иначе демон
# продолжает крутить старый код до планового прогона вотчдога (10 мин) — а до его
# появления это дважды приводило к инцидентам («фикс есть, поведение прежнее»).
# Любой сбой тихо игнорим: хук НИКОГДА не должен ломать git-операцию.
changed=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null) || exit 0
echo "$changed" | grep -qE '^(host-runner|programmer-runner|codex-runner|pipeline-runner)/(bin|src)/' || exit 0
dir=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden \
  -File "$dir/scripts/ensure-fresh-runners.ps1" >/dev/null 2>&1 &
exit 0
