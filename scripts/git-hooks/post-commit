#!/bin/sh
# Пост-коммит: две авто-свежести. Любой сбой тихо игнорим: хук НИКОГДА не должен
# ломать git-операцию.
changed=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null) || exit 0
dir=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0

# RUNNER-FRESHNESS-001 — коммит, трогающий код хостовых демонов, немедленно
# запускает вотчдог свежести (точечный рестарт устаревшего демона). Иначе демон
# продолжает крутить старый код до планового прогона вотчдога (10 мин) — а до его
# появления это дважды приводило к инцидентам («фикс есть, поведение прежнее»).
if echo "$changed" | grep -qE '^(host-runner|programmer-runner|codex-runner|pipeline-runner)/(bin|src)/'; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden \
    -File "$dir/scripts/ensure-fresh-runners.ps1" >/dev/null 2>&1 &
fi

# CODEBASE-MEMORY-AUTOREFRESH-001 — коммит, трогающий ИСХОДНИКИ вложенного
# memory-корня, инкрементально обновляет его codebase-memory (корень репо ведут
# глобальные хуки Claude Code). Правки самих memory-файлов игнорим, иначе коммит
# памяти сам себя триггерит. См. scripts/refresh-codebase-memory.ps1.
mem() {
  powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden \
    -File "$dir/scripts/refresh-codebase-memory.ps1" "$@" >/dev/null 2>&1 &
}
# Memory-артефакты codebase-memory: их правки НЕ должны триггерить refresh (иначе
# коммит регенерированной памяти сам себя триггерит). Это .claude/*, CLAUDE.md,
# CONVENTIONS.md и IDE-файлы (.cursorrules/.clinerules/.windsurfrules/.roomodes,
# .github/copilot-instructions.md).
mem_re='(^|/)\.claude/|(^|/)(CLAUDE|CONVENTIONS)\.md$|(^|/)\.(cursorrules|clinerules|windsurfrules|roomodes)$|(^|/)copilot-instructions\.md$'
touched() {
  # истинно, если среди изменённых есть НЕ-memory файл под префиксом $1
  echo "$changed" | grep -E "^$1/" | grep -qvE "$mem_re"
}
touched 'orchestrator-service/backend' && mem -Only 'orchestrator-service/backend'
touched 'programmer-runner'            && mem -Only 'programmer-runner'

exit 0
